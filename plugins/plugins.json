{
  "version": 1,
  "plugins": [
    {
      "name": "beads",
      "description": "Issue tracking plugin for beads_rust (br)",
      "tags": ["issues", "tracking", "project-management"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/beads/plugin.json"
      }
    },
    {
      "name": "gwc",
      "description": "Google Workspace CLI passthrough plugin",
      "tags": ["google", "workspace", "api", "passthrough"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/gwc/plugin.json"
      }
    },
    {
      "name": "docker",
      "description": "Docker harness with guarded non-TTY interactive command safety",
      "tags": ["docker", "containers", "devops", "harness"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/docker/plugin.json"
      }
    },
    {
      "name": "stripe",
      "description": "Stripe CLI plugin with core commands and passthrough",
      "tags": ["stripe", "payments", "billing", "passthrough"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/stripe/plugin.json"
      }
    },
    {
      "name": "vercel",
      "description": "Vercel CLI plugin with account wrapper and passthrough",
      "tags": ["vercel", "deployments", "hosting", "passthrough"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/vercel/plugin.json"
      }
    },
    {
      "name": "linear",
      "description": "Linear CLI plugin with account wrapper and passthrough",
      "tags": ["linear", "issues", "project-management", "passthrough"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/linear/plugin.json"
      }
    },
    {
      "name": "railway",
      "description": "Railway CLI plugin with account wrapper and passthrough",
      "tags": ["railway", "deployments", "infrastructure", "passthrough"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/railway/plugin.json"
      }
    },
    {
      "name": "commiat",
      "description": "AI-assisted git commit message plugin",
      "tags": ["git", "commit", "ai", "developer-experience"],
      "source": {
        "type": "git",
        "repo": "https://github.com/javimosch/commiat.git",
        "ref": "master",
        "manifest_path": "plugins/supercli/plugin.json"
      }
    },
    {
      "name": "agency-agents",
      "description": "Indexes remote skills from msitarzewski/agency-agents into skills catalog",
      "tags": ["skills", "agents", "catalog", "remote"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/agency-agents/plugin.json"
      }
    },
    {
      "name": "visual-explainer",
      "description": "Indexes normalized visual-explainer markdown skills from javimosch/visual-explainer",
      "tags": ["skills", "visualization", "catalog", "remote"],
      "source": {
        "type": "bundled",
        "manifest_path": "plugins/visual-explainer/plugin.json"
      }
    }
  ]
}
