{
  "name": "gifcap",
  "version": "1.0.0",
  "description": "Screen recording, cropping, and GIF optimization tool",
  "source": "https://github.com/javimosch/gifcap",
  "checks": [
    { "type": "binary", "name": "node" },
    { "type": "binary", "name": "npm" },
    { "type": "binary", "name": "ffmpeg" }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gifcap",
      "resource": "cli",
      "action": "setup",
      "description": "Install or link gifcap dependency",
      "adapter": "process",
      "adapterConfig": {
        "command": "node",
        "baseArgs": ["scripts/setup-gifcap.js"],
        "parseJson": false,
        "timeout_ms": 120000
      },
      "args": []
    },
    {
      "namespace": "gifcap",
      "resource": "screen",
      "action": "record",
      "description": "Record screen and create an optimized GIF or MP4",
      "adapter": "process",
      "adapterConfig": {
        "command": "gifcap",
        "baseArgs": ["record"],
        "jsonFlag": "--json",
        "parseJson": true,
        "missingDependencyHelp": "Please run 'dcli gifcap cli setup' to install gifcap."
      },
      "args": [
        { "name": "duration", "type": "number", "required": true, "description": "Duration in seconds to record" },
        { "name": "output", "alias": "o", "type": "string", "required": false, "description": "Output filename" },
        { "name": "top", "alias": "t", "type": "number", "required": false, "description": "Crop pixels from top" },
        { "name": "left", "alias": "l", "type": "number", "required": false, "description": "Crop pixels from left" },
        { "name": "bottom", "alias": "b", "type": "number", "required": false, "description": "Crop pixels from bottom" },
        { "name": "right", "alias": "r", "type": "number", "required": false, "description": "Crop pixels from right" },
        { "name": "speed", "type": "number", "required": false, "description": "Speed multiplier" },
        { "name": "mp4", "type": "boolean", "required": false, "description": "Output MP4 instead of GIF" },
        { "name": "quiet", "type": "boolean", "required": false, "description": "Suppress non-essential output", "default": true },
        { "name": "yes", "type": "boolean", "required": false, "description": "Skip confirmations", "default": true }
      ]
    },
    {
      "namespace": "gifcap",
      "resource": "media",
      "action": "optimize",
      "description": "Optimize an existing GIF file",
      "adapter": "process",
      "adapterConfig": {
        "command": "gifcap",
        "baseArgs": ["optimize"],
        "positionalArgs": ["input"],
        "jsonFlag": "--json",
        "parseJson": true,
        "missingDependencyHelp": "Please run 'dcli gifcap cli setup' to install gifcap."
      },
      "args": [
        { "name": "input", "type": "string", "required": true, "description": "Path to input GIF" },
        { "name": "output", "alias": "o", "type": "string", "required": false, "description": "Output filename" },
        { "name": "target-size", "alias": "ts", "type": "number", "required": false, "description": "Target size in MB" },
        { "name": "fps", "type": "number", "required": false, "description": "Target FPS" },
        { "name": "colors", "type": "number", "required": false, "description": "Max colors" },
        { "name": "yes", "type": "boolean", "required": false, "description": "Skip confirmations", "default": true }
      ]
    },
    {
      "namespace": "gifcap",
      "resource": "media",
      "action": "cut",
      "description": "Cut seconds from the start/end of a GIF",
      "adapter": "process",
      "adapterConfig": {
        "command": "gifcap",
        "baseArgs": ["cut"],
        "positionalArgs": ["input"],
        "jsonFlag": "--json",
        "parseJson": true,
        "missingDependencyHelp": "Please run 'dcli gifcap cli setup' to install gifcap."
      },
      "args": [
        { "name": "input", "type": "string", "required": true, "description": "Path to input GIF" },
        { "name": "output", "alias": "o", "type": "string", "required": false, "description": "Output filename" },
        { "name": "start", "alias": "s", "type": "number", "required": false, "description": "Seconds to cut from start" },
        { "name": "end", "alias": "e", "type": "number", "required": false, "description": "Seconds to cut from end" }
      ]
    },
    {
      "namespace": "gifcap",
      "resource": "media",
      "action": "convert",
      "description": "Convert MP4 to GIF",
      "adapter": "process",
      "adapterConfig": {
        "command": "gifcap",
        "baseArgs": ["convert"],
        "positionalArgs": ["input"],
        "jsonFlag": "--json",
        "parseJson": true,
        "missingDependencyHelp": "Please run 'dcli gifcap cli setup' to install gifcap."
      },
      "args": [
        { "name": "input", "type": "string", "required": true, "description": "Path to input MP4" },
        { "name": "output", "alias": "o", "type": "string", "required": false, "description": "Output filename" }
      ]
    }
  ]
}
