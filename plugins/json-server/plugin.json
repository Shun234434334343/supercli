{
  "name": "json-server",
  "version": "0.1.0",
  "description": "@javimosch/json-server plugin with agent-friendly server lifecycle wrappers and passthrough",
  "source": "https://github.com/javimosch/json-server",
  "checks": [
    { "type": "binary", "name": "json-server" }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "json-server",
      "resource": "cli",
      "action": "version",
      "description": "Show installed json-server version",
      "adapter": "process",
      "adapterConfig": {
        "command": "json-server",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Install with: npm install -g @javimosch/json-server"
      },
      "args": []
    },
    {
      "namespace": "json-server",
      "resource": "server",
      "action": "start",
      "description": "Start json-server in background and return immediately",
      "adapter": "process",
      "adapterConfig": {
        "command": "json-server",
        "baseArgs": ["server", "start"],
        "parseJson": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install with: npm install -g @javimosch/json-server"
      },
      "args": [
        { "name": "file", "type": "string", "required": true, "description": "Path to db.json or db.json5" },
        { "name": "port", "type": "integer", "required": false, "description": "Port to bind (default: 3000)" },
        { "name": "host", "type": "string", "required": false, "description": "Host to bind (default: localhost)" },
        { "name": "state-dir", "type": "string", "required": false, "description": "Local state directory for PID/log/state files" },
        { "name": "static", "type": "string[]", "required": false, "description": "Additional static directories (repeatable)" }
      ]
    },
    {
      "namespace": "json-server",
      "resource": "server",
      "action": "status",
      "description": "Check whether background json-server is running",
      "adapter": "process",
      "adapterConfig": {
        "command": "json-server",
        "baseArgs": ["server", "status"],
        "parseJson": true,
        "missingDependencyHelp": "Install with: npm install -g @javimosch/json-server"
      },
      "args": [
        { "name": "state-dir", "type": "string", "required": false, "description": "Local state directory for PID/log/state files" }
      ]
    },
    {
      "namespace": "json-server",
      "resource": "server",
      "action": "logs",
      "description": "Get recent background server logs",
      "adapter": "process",
      "adapterConfig": {
        "command": "json-server",
        "baseArgs": ["server", "logs"],
        "parseJson": true,
        "missingDependencyHelp": "Install with: npm install -g @javimosch/json-server"
      },
      "args": [
        { "name": "state-dir", "type": "string", "required": false, "description": "Local state directory for PID/log/state files" },
        { "name": "lines", "type": "integer", "required": false, "description": "How many recent log lines to return" }
      ]
    },
    {
      "namespace": "json-server",
      "resource": "server",
      "action": "stop",
      "description": "Stop background json-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "json-server",
        "baseArgs": ["server", "stop"],
        "parseJson": true,
        "missingDependencyHelp": "Install with: npm install -g @javimosch/json-server"
      },
      "args": [
        { "name": "state-dir", "type": "string", "required": false, "description": "Local state directory for PID/log/state files" }
      ]
    },
    {
      "namespace": "json-server",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any json-server CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "json-server",
        "passthrough": true,
        "parseJson": true,
        "timeout_ms": 180000,
        "missingDependencyHelp": "Install with: npm install -g @javimosch/json-server"
      },
      "args": []
    }
  ]
}
