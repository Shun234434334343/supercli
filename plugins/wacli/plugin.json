{
  "name": "wacli",
  "version": "0.1.0",
  "description": "wacli WhatsApp CLI plugin with safe read-only wrappers",
  "source": "https://github.com/steipete/wacli",
  "checks": [
    {
      "type": "binary",
      "name": "wacli"
    }
  ],
  "commands": [
    {
      "namespace": "wacli",
      "resource": "cli",
      "action": "version",
      "description": "Show wacli CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wacli",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install wacli to use this command."
      },
      "args": []
    },
    {
      "namespace": "wacli",
      "resource": "doctor",
      "action": "run",
      "description": "Run wacli diagnostics as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "wacli",
        "baseArgs": ["doctor", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install wacli to use this command."
      },
      "args": [
        { "name": "store", "type": "string", "required": false }
      ]
    },
    {
      "namespace": "wacli",
      "resource": "auth",
      "action": "status",
      "description": "Show authentication status as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "wacli",
        "baseArgs": ["auth", "status", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install wacli to use this command."
      },
      "args": [
        { "name": "store", "type": "string", "required": false }
      ]
    },
    {
      "namespace": "wacli",
      "resource": "chats",
      "action": "list",
      "description": "List chats as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "wacli",
        "baseArgs": ["chats", "list", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install wacli to use this command."
      },
      "args": [
        { "name": "store", "type": "string", "required": false },
        { "name": "query", "type": "string", "required": false },
        { "name": "limit", "type": "integer", "required": false }
      ]
    },
    {
      "namespace": "wacli",
      "resource": "chats",
      "action": "show",
      "description": "Show a chat by JID as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "wacli",
        "baseArgs": ["chats", "show", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install wacli to use this command."
      },
      "args": [
        { "name": "jid", "type": "string", "required": true },
        { "name": "store", "type": "string", "required": false }
      ]
    },
    {
      "namespace": "wacli",
      "resource": "messages",
      "action": "list",
